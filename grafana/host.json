          "instant": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "label_join(sum by (gpu, user) (nvml_user_gpu_processes{instance=\"$instance\", gpu=~\"$gpu\"}), \"key\", \"|\", \"user\", \"gpu\")",
          "format": "table",
          "instant": true,
          "refId": "B"
