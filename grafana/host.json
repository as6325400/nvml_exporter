        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "label_join(sum by (gpu, user) (nvml_user_gpu_sm_utilization_ratio{instance=\"$instance\", gpu=~\"$gpu\"}), \"key\", \"|\", \"user\", \"gpu\")",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "title": "Current per-user breakdown",
      "transformations": [
        { "id": "joinByField", "options": { "byField": "key", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true, "Time 3": true,
              "key": true,
              "gpu 2": true, "gpu 3": true,
              "user 2": true, "user 3": true
            },
            "indexByName": {
              "gpu 1": 0, "user 1": 1, "Value #A": 2, "Value #B": 3, "Value #C": 4
            },
            "renameByName": {
              "gpu 1": "GPU",
              "user 1": "User",
              "Value #A": "Memory",
              "Value #B": "Processes",
              "Value #C": "SM Util"
            }
          }
        }
      ],
      "type": "table"
    }
