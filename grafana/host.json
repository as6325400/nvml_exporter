          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Memory" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "SM Util" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "max", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Processes" },
            "properties": [{ "id": "unit", "value": "none" }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
