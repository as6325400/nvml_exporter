{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "NVML cluster overview — per-node summary. Click a host in the table to open the per-user detail dashboard.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Host detail",
      "tooltip": "Drill into a single host's per-user breakdown",
      "type": "link",
      "url": "/d/nvml-host-detail"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(nvml_up == 1)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Hosts Up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * sum(nvml_gpu_memory_used_bytes) / sum(nvml_gpu_memory_total_bytes)",
          "refId": "A"
        }
      ],
      "title": "Cluster GPU Memory Used",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(count by (user) (nvml_user_gpu_memory_bytes{user!=\"<gone>\"} > 0)) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Active Users (cluster)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 600 }, { "color": "red", "value": 1000 }] },
          "unit": "watt"
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(nvml_gpu_power_watts) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Total Power",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }] },
          "unit": "celsius"
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["max"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "max(nvml_gpu_temperature_celsius)",
          "refId": "A"
        }
      ],
      "title": "Max GPU Temp",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "One row per host. Click the host name to open the per-user detail dashboard.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Host" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open per-user detail for ${__value.raw}",
                    "url": "/d/nvml-host-detail?var-instance=${__value.raw}&${__url_time_range}",
                    "targetBlank": false
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Mem Used" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Mem %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Power" },
            "properties": [{ "id": "unit", "value": "watt" }]
          },
          {
            "matcher": { "id": "byName", "options": "Max Temp" },
            "properties": [{ "id": "unit", "value": "celsius" }]
          },
          {
            "matcher": { "id": "byName", "options": "GPUs" },
            "properties": [{ "id": "unit", "value": "none" }]
          },
          {
            "matcher": { "id": "byName", "options": "Active Users" },
            "properties": [{ "id": "unit", "value": "none" }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Mem %" }]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count by (instance) (nvml_gpu_memory_total_bytes)",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (instance) (nvml_gpu_memory_used_bytes)",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * sum by (instance) (nvml_gpu_memory_used_bytes) / sum by (instance) (nvml_gpu_memory_total_bytes)",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (instance) (nvml_gpu_power_watts)",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "max by (instance) (nvml_gpu_temperature_celsius)",
          "format": "table",
          "instant": true,
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count by (instance) (count by (instance, user) (nvml_user_gpu_memory_bytes{user!=\"<gone>\"} > 0))",
          "format": "table",
          "instant": true,
          "refId": "F"
        }
      ],
      "title": "Per-host summary (click Host to drill down)",
      "transformations": [
        { "id": "joinByField", "options": { "byField": "instance", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true, "Time 3": true,
              "Time 4": true, "Time 5": true, "Time 6": true
            },
            "indexByName": {
              "instance": 0,
              "Value #A": 1, "Value #B": 2, "Value #C": 3,
              "Value #D": 4, "Value #E": 5, "Value #F": 6
            },
            "renameByName": {
              "instance": "Host",
              "Value #A": "GPUs",
              "Value #B": "Mem Used",
              "Value #C": "Mem %",
              "Value #D": "Power",
              "Value #E": "Max Temp",
              "Value #F": "Active Users"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (instance) (nvml_gpu_memory_used_bytes)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "GPU Memory Used by Host",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 21,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "max by (instance) (nvml_gpu_utilization_ratio)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Max GPU SM Util by Host",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none",
          "min": 0,
          "decimals": 0
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "id": 22,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count by (instance) (count by (instance, user) (nvml_user_gpu_memory_bytes{user!=\"<gone>\"} > 0)) or label_replace(vector(0), \"instance\", \"(none)\", \"\", \"\")",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Active Users by Host",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["gpu", "nvml", "nvidia"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NVML GPU Cluster Overview",
  "uid": "nvml-cluster-overview",
  "version": 1,
  "weekStart": ""
}
